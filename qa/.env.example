# Environment Variables for Easy Kanban QA Tests
# Copy this file to .env and fill in your credentials

# Test user credentials
TEST_USER_EMAIL=your-email@example.com
TEST_USER_PASSWORD=your-password-here

# Base URL for tests
# Local development: http://localhost:3222
# Remote server: https://kanban.drenlia.dev
PLAYWRIGHT_BASE_URL=https://kanban.drenlia.dev
